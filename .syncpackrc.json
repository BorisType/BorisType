{
  "$schema": "https://unpkg.com/syncpack@13/dist/schema.json",
  "versionGroups": [
    {
      "label": "Exact-pinned workspace deps in bt-cli (bt-ir, runtime)",
      "packages": ["@boristype/bt-cli"],
      "dependencies": ["@boristype/bt-ir", "@boristype/runtime", "@boristype/ws-client", "@boristype/ws-version"],
      "dependencyTypes": ["prod", "peer"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Workspace packages use workspace:^ protocol",
      "dependencies": [
        "@boristype/bt-cli",
        "@boristype/bt-ir",
        "@boristype/eslint-plugin",
        "@boristype/runtime",
        "@boristype/ws-client",
        "@boristype/ws-version",
        "boristype-example-library"
      ],
      "dependencyTypes": [
        "dev",
        "prod",
        "peer"
      ],
      "pinVersion": "workspace:^"
    },
    {
      "label": "ESLint aligned",
      "dependencies": ["eslint"],
      "dependencyTypes": ["dev", "prod"],
      "pinVersion": "^9.0.0"
    },
    {
      "label": "ESLint TS parser aligned",
      "dependencies": ["@typescript-eslint/parser"],
      "pinVersion": "^8.0.0"
    },
    {
      "label": "TypeScript aligned to latest",
      "dependencies": ["typescript"],
      "pinVersion": "^5.9.2"
    },
    {
      "label": "@types/node aligned",
      "dependencies": ["@types/node"],
      "pinVersion": "^24.7.2"
    },
    {
      "label": "fast-xml-parser aligned",
      "dependencies": ["fast-xml-parser"],
      "pinVersion": "^5.3.3"
    }
  ]
}
