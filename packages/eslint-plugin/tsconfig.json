{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}
