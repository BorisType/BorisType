// objects_fetch.bs
//
// Получает полный XML-документ объекта по ID.
// Вход: object_id подставляется через шаблон {{object_id}}
// Выход: XML-строка документа
//
// var sObjectId = '{{object_id}}';
// ...
// return XML-строку

try {
  var doc = tools.open_doc("{{object_id}}");
  return tools.object_to_text({ error: false, data: doc.TopElem.Xml }, 'json');
} catch (err) {
  return tools.object_to_text({ error: true, message: (err + "") }, 'json');
}
